# ── Bot do Telegram ────────────────────────────────────────────────────────
# Obtenha com @BotFather no Telegram
TELEGRAM_TOKEN=seu_token_aqui

# ── OpenAI (GPT-4o Vision) ─────────────────────────────────────────────────
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Google Sheets ──────────────────────────────────────────────────────────
# ID da planilha (parte da URL: docs.google.com/spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEETS_ID=id_da_planilha_aqui

# Caminho para o arquivo de credenciais da conta de serviço Google
GOOGLE_CREDENTIALS_FILE=credentials.json

# ── Segurança (opcional) ───────────────────────────────────────────────────
# IDs do Telegram que podem usar o bot (separe por vírgula)
# Deixe em branco para permitir qualquer pessoa
# Para saber seu ID: fale com @userinfobot no Telegram
ALLOWED_USER_IDS=123456789
